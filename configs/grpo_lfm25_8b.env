# LFM2.5-8B-A1B Graph-GRPO — H200 x4 full-VRAM colocate config
# Sourced by scripts/04_run_grpo.sh. Also sources configs/env_common.sh.
source "$(dirname "${BASH_SOURCE[0]}")/env_common.sh"

export BASE_MODEL_DIR="./checkpoints/orpo_lfm25_8b"
export TOKENIZER_MODEL="/home/work/.cache/hf_models/LFM2.5-8B-A1B"
export DATASET_REPO="lamm-mit/graph_reasoning_10K"
export PROCESSED_DATASET="./data/processed/grpo.jsonl"

export OUTPUT_DIR="./checkpoints/grpo_lfm25_8b"
export HUB_MODEL_ID="LLM-OS-Models/LFM2.5-8B-A1B-Graph-Preflexor-GRPO"
export HUB_PUBLIC=1

# GPU layout: all 4. vLLM colocate shares them.
export TRAIN_GPUS="2,3,4,5"
export NPROC_PER_NODE=4
export VLLM_MODE="colocate"
export VLLM_COLOCATE_GPU_MEM_UTIL=0.55    # ~75GB for vLLM cache + train weights

# Paper 8B GRPO shape, but bigger batches since LFM2.5 is A1B
export LR=5e-6
export EPOCHS=1
export NUM_GENERATIONS=8
export PER_DEVICE_BATCH=2
export GRAD_ACCUM=2                       # effective batch = 2*2*4 = 16 prompts × 8 gens = 128 rollouts
export MAX_PROMPT_LENGTH=1536
export MAX_COMPLETION_LENGTH=3500
export TEMPERATURE=1.0
export SAVE_STEPS=25
export LOGGING_STEPS=5

export SCALE_REWARDS=batch
export LOSS_TYPE=dapo

# Reward weights (paper Table 2)
export WEIGHT_CORRECTNESS=0.30
export WEIGHT_FORMAT=0.15
export WEIGHT_GRAPH_UTILITY=0.25
export WEIGHT_GRAPH_NETWORKX=0.10
export WEIGHT_GRAPH_DIVERSITY=0.10
export WEIGHT_GRAPH_STRUCTURE=0.10

# Judge queue calibration
export JUDGE_MODE="embedding_with_claude_queue"
export JUDGE_QUEUE_DIR="./judge"
export JUDGE_QUEUE_EVERY_STEPS=25
export JUDGE_QUEUE_BATCH_SIZE=16
export EMBED_MODEL="BAAI/bge-base-en-v1.5"
export CLAUDE_BLEND_ALPHA=0.5

export LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LORA_R=32
export LORA_ALPHA=64
export LORA_DROPOUT=0.05

export CHAT_TEMPLATE_ENABLE_THINKING=false
export ADD_NEW_SPECIAL_TOKENS=false

export WANDB_RUN_GROUP="lfm25-grpo"
