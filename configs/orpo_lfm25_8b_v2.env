# LFM2.5-8B-A1B ORPO v2 — special tokens registered, epoch 2, larger batch
# Sourced by scripts/03_run_orpo.sh. Also sources configs/env_common.sh.
source "$(dirname "${BASH_SOURCE[0]}")/env_common.sh"

export MODEL_ID="${MODEL_ID:-/home/work/.cache/hf_models/LFM2.5-8B-A1B}"
export DATASET_REPO="lamm-mit/graph_reasoning_10K"
export PROCESSED_DATASET="./data/processed/orpo.jsonl"

export OUTPUT_DIR="./checkpoints/orpo_lfm25_8b_v2"
export HUB_MODEL_ID="LLM-OS-Models/LFM2.5-8B-A1B-Graph-Preflexor-ORPO-v2"
export HUB_PUBLIC=1

# GPU layout: all 4 (H200 × 4)
export TRAIN_GPUS="2,3,4,5"
export NPROC_PER_NODE=4

# LFM2.5 MoE targets (attention + MLP linear; router not LoRA'd)
export LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LORA_R=32
export LORA_ALPHA=64
export LORA_DROPOUT=0.05

# Larger effective batch than v1 (was 8*2*4=64). v2: 8*4*4 = 128.
export LR=2e-5
export EPOCHS=2
export BATCH_SIZE=8
export GRAD_ACCUM=4
export MAX_LENGTH=4096
export SAVE_STEPS=50
export EVAL_STEPS=50
export LOGGING_STEPS=5

# KEY CHANGE: register sentinels as real special tokens so model can learn them
# launcher checks == "1"
export ADD_NEW_SPECIAL_TOKENS=1

export MODE=orpo
export CHAT_TEMPLATE_ENABLE_THINKING=false

export WANDB_RUN_GROUP="lfm25-orpo-v2"
