# LFM2.5-8B-A1B ORPO cold start
export MODEL_ID="LiquidAI/LFM2.5-8B-A1B"
export DATASET_REPO="lamm-mit/graph_reasoning_10K"
export PROCESSED_DATASET="./data/processed/orpo_lfm25.jsonl"

export OUTPUT_DIR="./checkpoints/orpo_lfm25"
export HUB_MODEL_ID="LLM-OS-Models/LFM2.5-8B-A1B-Graph-Preflexor-ORPO"
export HUB_PUBLIC=1

# H200 x8: 4 train ranks (DDP), no tensor parallel for 8B-MoE LoRA
export NPROC_PER_NODE=4
export TRAIN_GPUS="0,1,2,3"

# LFM2.5 MoE: target attention + MLP linear (router is not a LoRA target by default)
export LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LORA_R=32
export LORA_ALPHA=64
export LORA_DROPOUT=0.05

# Paper 8B settings: lr 1e-5, 1 epoch, max_len 2048
export LR=1e-5
export EPOCHS=1
export BATCH_SIZE=2
export GRAD_ACCUM=4
export MAX_LENGTH=4096
export SAVE_STEPS=100
export EVAL_STEPS=100
export LOGGING_STEPS=10

export MODE=orpo
export CHAT_TEMPLATE_ENABLE_THINKING=false
export ADD_NEW_SPECIAL_TOKENS=false

export WANDB_PROJECT="graph-preflexor-lfm25"
export WANDB_RUN_GROUP="lfm25-orpo"
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
