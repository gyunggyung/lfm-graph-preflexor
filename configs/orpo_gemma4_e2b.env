# gemma-4-E2B-it ORPO cold start — H200 x4
# E2B = Effective 2B (MIXED-FIDELITY / Per-Layer MoE routing) — small but capable
source "$(dirname "${BASH_SOURCE[0]}")/env_common.sh"

# Use principled-intelligence text-only extraction (Gemma4TextModel, model_type=gemma4_text)
# — avoids needing to extract from the multimodal Gemma4ForConditionalGeneration
_E2B_DIR=$(find /home/work/.cache/huggingface/hub/models--principled-intelligence--gemma-4-E2B-it-text-only/snapshots/ -maxdepth 1 -mindepth 1 -type d 2>/dev/null | head -1)
export MODEL_ID="${MODEL_ID:-$_E2B_DIR}"
unset _E2B_DIR
export DATASET_REPO="lamm-mit/graph_reasoning_10K"
export PROCESSED_DATASET="./data/processed/orpo.jsonl"

export OUTPUT_DIR="./checkpoints/orpo_gemma4_e2b"
export HUB_MODEL_ID="LLM-OS-Models/gemma-4-E2B-it-Graph-Preflexor-ORPO"
export HUB_PUBLIC=1

export TRAIN_GPUS="2,3,4,5"
export NPROC_PER_NODE=4

# gemma architecture uses different projections names; try all-linear as fallback
export LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LORA_R=32
export LORA_ALPHA=64
export LORA_DROPOUT=0.05

# E2B is small (~3B effective) — can pack big batches
export LR=1e-5
export EPOCHS=2
export BATCH_SIZE=4
export GRAD_ACCUM=4
export MAX_LENGTH=4096
export SAVE_STEPS=50
# ORPO eval uses concatenated_forward which OOMs at MAX_LENGTH=4096. Disable.
export EVAL_STEPS=100000
export LOGGING_STEPS=5

export ADD_NEW_SPECIAL_TOKENS=1

export MODE=orpo
# gemma-4 has its own thinking mode; default off (will learn from chosen)
export CHAT_TEMPLATE_ENABLE_THINKING=false

export WANDB_RUN_GROUP="gemma4-e2b-orpo"
