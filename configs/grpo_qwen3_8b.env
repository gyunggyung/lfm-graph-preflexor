# Qwen3-8B Graph-GRPO (paper reproduction control)
export BASE_MODEL_DIR="./checkpoints/orpo_qwen3"
export TOKENIZER_MODEL="Qwen/Qwen3-8B"
export DATASET_REPO="lamm-mit/graph_reasoning_10K"
export PROCESSED_DATASET="./data/processed/grpo_qwen3.jsonl"

export OUTPUT_DIR="./checkpoints/grpo_qwen3"
export HUB_MODEL_ID="LLM-OS-Models/Qwen3-8B-Graph-Preflexor-GRPO-Repro"
export HUB_PUBLIC=1

export NPROC_PER_NODE=4
export TRAIN_GPUS="4,5,6,7"
export VLLM_GPUS="0,1,2,3"
export VLLM_PORTS="8123,8124,8125,8126"
export VLLM_GPU_MEM_UTIL=0.85

# Paper Qwen3-8B GRPO: group 8, lr 5e-6, 3 epochs, max_completion 3500
export LR=5e-6
export EPOCHS=3
export NUM_GENERATIONS=8
export PER_DEVICE_BATCH=1
export GRAD_ACCUM=8
export MAX_PROMPT_LENGTH=1536
export MAX_COMPLETION_LENGTH=3500
export TEMPERATURE=1.0
export SAVE_STEPS=100
export LOGGING_STEPS=10

export SCALE_REWARDS=batch
export LOSS_TYPE=dapo

export WEIGHT_CORRECTNESS=0.30
export WEIGHT_FORMAT=0.15
export WEIGHT_GRAPH_UTILITY=0.25
export WEIGHT_GRAPH_NETWORKX=0.10
export WEIGHT_GRAPH_DIVERSITY=0.10
export WEIGHT_GRAPH_STRUCTURE=0.10

export JUDGE_MODE="embedding_with_claude_queue"
export JUDGE_QUEUE_DIR="./judge"
export JUDGE_QUEUE_EVERY_STEPS=100
export JUDGE_QUEUE_BATCH_SIZE=16
export EMBED_MODEL="BAAI/bge-base-en-v1.5"

export LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LORA_R=16
export LORA_ALPHA=32
export LORA_DROPOUT=0.05

export CHAT_TEMPLATE_ENABLE_THINKING=true
export ADD_NEW_SPECIAL_TOKENS=false

export WANDB_PROJECT="graph-preflexor-lfm25"
export WANDB_RUN_GROUP="qwen3-grpo"
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
