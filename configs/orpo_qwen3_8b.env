# Qwen3-8B ORPO cold start (paper reproduction control)
export MODEL_ID="Qwen/Qwen3-8B"
export DATASET_REPO="lamm-mit/graph_reasoning_10K"
export PROCESSED_DATASET="./data/processed/orpo_qwen3.jsonl"

export OUTPUT_DIR="./checkpoints/orpo_qwen3"
export HUB_MODEL_ID="LLM-OS-Models/Qwen3-8B-Graph-Preflexor-ORPO-Repro"
export HUB_PUBLIC=1

export NPROC_PER_NODE=4
export TRAIN_GPUS="0,1,2,3"

export LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LORA_R=16
export LORA_ALPHA=32
export LORA_DROPOUT=0.05

# Paper Qwen3-8B: lr 1e-5, 1 epoch
export LR=1e-5
export EPOCHS=1
export BATCH_SIZE=2
export GRAD_ACCUM=4
export MAX_LENGTH=2048
export SAVE_STEPS=100
export EVAL_STEPS=100
export LOGGING_STEPS=10

export MODE=orpo
# Qwen3 has native thinking; paper uses enable_thinking=true via chat template
export CHAT_TEMPLATE_ENABLE_THINKING=true
export ADD_NEW_SPECIAL_TOKENS=false

export WANDB_PROJECT="graph-preflexor-lfm25"
export WANDB_RUN_GROUP="qwen3-orpo"
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
