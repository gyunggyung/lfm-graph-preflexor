# Qwen3.5-9B ORPO cold start — H200 x4
# Sourced by scripts/03_run_orpo.sh. Also sources configs/env_common.sh.
source "$(dirname "${BASH_SOURCE[0]}")/env_common.sh"

export MODEL_ID="${MODEL_ID:-/home/work/.cache/hf_models/Qwen3.5-9B-text}"
export DATASET_REPO="lamm-mit/graph_reasoning_10K"
export PROCESSED_DATASET="./data/processed/orpo.jsonl"

export OUTPUT_DIR="./checkpoints/orpo_qwen35_9b"
export HUB_MODEL_ID="LLM-OS-Models/Qwen3.5-9B-Graph-Preflexor-ORPO"
export HUB_PUBLIC=1

export TRAIN_GPUS="2,3,4,5"
export NPROC_PER_NODE=4

# Qwen3.5 dense 9B — same LoRA targets as Qwen3-8B
export LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LORA_R=32
export LORA_ALPHA=64
export LORA_DROPOUT=0.05

# Qwen3.5 dense 9B — heavier per-step than MoE, keep eff batch 64
export LR=1e-5
export EPOCHS=2
export BATCH_SIZE=2
export GRAD_ACCUM=8
export MAX_LENGTH=4096
export SAVE_STEPS=50
# ORPO eval uses concatenated_forward (chosen+rejected together) which OOMs on 9B + seq 4096.
# Final eval done separately via vLLM. Disable in-training eval.
export EVAL_STEPS=100000
export LOGGING_STEPS=5

# Register sentinels as real special tokens
export ADD_NEW_SPECIAL_TOKENS=1

export MODE=orpo
# Qwen3 family supports native thinking; enable_thinking=true matches paper
export CHAT_TEMPLATE_ENABLE_THINKING=true

export WANDB_RUN_GROUP="qwen35-orpo"
